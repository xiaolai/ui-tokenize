    "body-small":    { "$value": "12px", "$type": "dimension" },
    "body-medium":   { "$value": "14px", "$type": "dimension" },
    "body-large":    { "$value": "16px", "$type": "dimension" },
    "title-small":   { "$value": "14px", "$type": "dimension" },
    "title-medium":  { "$value": "16px", "$type": "dimension" },
    "title-large":   { "$value": "22px", "$type": "dimension" },
    "headline-small":  { "$value": "24px", "$type": "dimension" },
    "headline-medium": { "$value": "28px", "$type": "dimension" },
    "headline-large":  { "$value": "32px", "$type": "dimension" }
